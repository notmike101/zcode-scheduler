{
  "apiVersion": 1,
  "id": "scheduler",
  "name": "Scheduler",
  "version": "0.1.5",
  "description": "Create normal ZCode tasks from timezone-aware cron schedules while ZCode is open.",
  "entrypoints": {
    "main": "dist/main.cjs",
    "renderer": "dist/renderer.js"
  },
  "engines": {
    "host": ">=0.3.4 <1",
    "zcode": ">=3.3.6"
  },
  "capabilities": [
    "zcode.workspaces.read",
    "zcode.tasks.run",
    "ui.pages",
    "ui.overlays"
  ],
  "pages": [
    {"id": "jobs", "title": "Scheduler"}
  ]
}
